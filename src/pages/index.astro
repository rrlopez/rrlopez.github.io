---
import { personal } from '../data/personal';
import HomeLayout from '../layouts/HomeLayout.astro';
---

<HomeLayout title={"RJ Lopez — Senior Full Stack Engineer"} description={"Ricardo Rey Crisanto V. Lopez II (RJ) — Senior Full Stack Engineer, 7+ years building scalable SaaS platforms with the JavaScript/TypeScript ecosystem."}>
  <!-- ===== NAV ===== -->
  <nav class="sticky top-0 z-10 bg-bg/90 backdrop-blur border-b border-border print:hidden" aria-label="Section navigation">
    <div class="max-w-6xl mx-auto px-6 py-3 flex items-center justify-between">
      <a href="#top" class="font-bold text-text tracking-tight">RJ<span class="text-accent">.</span>dev</a>
      <div class="flex items-center gap-5 text-sm font-medium text-text-secondary">
        <a href="#experience" class="hover:text-accent transition-colors">Experience</a>
        <a href="#projects" class="hover:text-accent transition-colors">Projects</a>
        <a href="#skills" class="hover:text-accent transition-colors">Skills</a>
        <a href="#blog" class="hover:text-accent transition-colors">Blog</a>
        <a href="#contact" class="hover:text-accent transition-colors">Contact</a>
        <button
          type="button"
          onclick="window.print()"
          aria-label="Download resume as PDF"
          class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg bg-accent text-bg text-xs font-semibold hover:bg-accent-2 hover:-translate-y-0.5 transition-all"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14"/></svg>
          Download Resume
        </button>
      </div>
    </div>
  </nav>

  <!-- ===== HEADER / HERO ===== -->
  <header id="top" class="border-b border-border">
    <div class="max-w-6xl mx-auto px-6 py-16 sm:py-20 print:py-4 flex flex-col sm:flex-row items-center sm:items-start gap-8 print:gap-0">

      <img
        src={personal.avatarUrl}
        alt={`Placeholder avatar for ${personal.fullName}`}
        width="160" height="160"
        class="w-32 h-32 sm:w-40 sm:h-40 rounded-full border-2 border-accent/40 shrink-0 object-cover print:hidden"
      >

      <div class="text-center sm:text-left">
        <div class="inline-flex items-center gap-2 mb-3 px-3 py-1 rounded-full bg-bg-elevated border border-border print:hidden">
          <span class="relative flex w-2 h-2">
            <span class="absolute inline-flex w-2 h-2 rounded-full bg-accent pulse-dot"></span>
            <span class="relative inline-flex w-2 h-2 rounded-full bg-accent"></span>
          </span>
          <span class="text-xs font-medium text-text-secondary">{personal.availability}</span>
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight">
          {personal.fullName} <span class="text-accent">({personal.nickname})</span>
        </h1>
        <p class="mt-2 text-base sm:text-lg text-text-secondary font-medium">
          {personal.title} <span class="text-accent-2">·</span> {personal.yearsExperience}+ Years Experience
        </p>
        <p class="mt-1 text-sm text-text-secondary flex items-center justify-center sm:justify-start gap-1.5">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21c-4.5-4.5-7-8.06-7-11a7 7 0 1 1 14 0c0 2.94-2.5 6.5-7 11Z"/><circle cx="12" cy="10" r="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {personal.location.display}
        </p>

        <p class="mt-4 max-w-xl text-text-secondary">
          {personal.bio}
        </p>
        <p class="mt-3 max-w-xl text-text-secondary italic print:hidden">
          {personal.tagline}
        </p>

        <!-- quick stats -->
        <div class="mt-6 flex justify-center sm:justify-start gap-6 sm:gap-8 print:hidden">
          {personal.stats.map((stat)=>(<div class="text-center sm:text-left">
            <p class="text-2xl font-bold text-accent">{stat.value}</p>
            <p class="text-xs text-text-secondary">{stat.label}</p>
          </div>))}
        </div>

        <div class="mt-6 flex flex-wrap justify-center sm:justify-start gap-3 print:hidden">
          <a href={`mailto:${personal.contact.email}`}
            class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-bg-elevated border border-border text-sm font-medium hover:border-accent hover:text-accent hover:-translate-y-0.5 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2Z"/></svg>
            {personal.contact.email}
          </a>
          <a href={`tel:+${personal.contact.phone.href}`}
            class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-bg-elevated border border-border text-sm font-medium hover:border-accent hover:text-accent hover:-translate-y-0.5 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 0 1 2-2h2.28a1 1 0 0 1 .98.78l.74 3.34a1 1 0 0 1-.27.96l-1.5 1.5a11 11 0 0 0 5.18 5.18l1.5-1.5a1 1 0 0 1 .96-.27l3.34.74a1 1 0 0 1 .78.98V19a2 2 0 0 1-2 2h-1C8.16 21 3 15.84 3 9V8Z"/></svg>
            {personal.contact.phone.display}
          </a>
          <a href={personal.social.github.url} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-bg-elevated border border-border text-sm font-medium hover:border-accent hover:text-accent hover:-translate-y-0.5 transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55v-1.94c-3.2.7-3.87-1.36-3.87-1.36-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.74.4-1.26.72-1.55-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.2-3.1-.12-.29-.52-1.46.11-3.04 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.83 0c2.22-1.49 3.2-1.18 3.2-1.18.63 1.58.23 2.75.11 3.04.75.81 1.2 1.84 1.2 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.77 1.07.77 2.15v3.19c0 .3.21.66.79.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>
            GitHub
          </a>
          <a href={personal.social.linkedin.url} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-bg-elevated border border-border text-sm font-medium hover:border-accent hover:text-accent hover:-translate-y-0.5 transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.75v20.5C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.75V1.75C24 .78 23.2 0 22.22 0Z"/></svg>
            LinkedIn
          </a>
        </div>

        <!-- print-only plain-text contact line: traditional resume header, no icons/buttons -->
        <p class="hidden print:block print:mt-2 print:text-sm">
          {personal.contact.email} &nbsp;|&nbsp; {personal.contact.phone.display} &nbsp;|&nbsp; {personal.social.linkedin.url} &nbsp;|&nbsp; {personal.social.portfolio.url}
        </p>
      </div>
    </div>
  </header>

   <!-- ===== ENGINEERING FOCUS (new) =====
         Short "what I build" line so a recruiter or EM gets the mindset in
         the first few seconds — before the project details. Kept short on
         purpose per the brief; renders as a comma list in print, like the
         Skills tags, so it doubles as a "core focus" line on the resume. -->
    <section class="border-b border-border bg-bg-elevated/40" aria-label="Core technologies print:hidden">
      <div class="max-w-6xl mx-auto px-6 py-6 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm font-semibold text-text-secondary print:hidden">
        <span>Offline-First Applications</span><span class="text-border">/</span>
        <span>SaaS &amp; Multi-Tenant Platforms</span><span class="text-border">/</span>
        <span>Clean, Maintainable Architecture</span><span class="text-border">/</span>
        <span>Engineering Systems</span><span class="text-border">/</span>
        <span>Modern TypeScript Ecosystem</span><span class="text-border">/</span>
        <span>Developer Experience Mindset</span><span class="text-border">/</span>
      </div>
    </section>

  <main class="max-w-6xl mx-auto px-6">
    
    <!-- ===== WORK HISTORY (TIMELINE) =====
         Each entry now opens with what the product/team was, before the
         impact bullets, so the reader gets context before detail. -->
    <section id="experience" class="py-14 border-b border-border scroll-mt-16" aria-labelledby="experience-heading">
      <h2 id="experience-heading" class="flex items-center gap-2 text-xl sm:text-2xl font-bold mb-7">
        <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span> Work History
      </h2>

      <div class="flex flex-col gap-10 print:gap-1">

        <div class="relative flex gap-5">
          <div class="relative w-3 shrink-0">
            <span class="absolute left-1.5 top-3 -bottom-10 w-px bg-border"></span>
            <span class="absolute left-0 top-1 w-3 h-3 rounded-full bg-bg border-2 border-accent"></span>
          </div>
          <div class="pb-2">
            <p class="font-bold">Senior Full Stack Developer · iScale</p>
            <p class="text-sm font-semibold text-accent-2 mt-0.5 mb-2.5">March 2025 — July 2026</p>
            <ul class="flex flex-col gap-2 text-sm text-text-secondary">
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Refactored legacy applications into reusable, maintainable React components.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Modernized UI using Material UI, React Hook Form, and shared component libraries.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Built responsive interfaces from Figma designs and maintained an internal design system.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Integrated Stripe, Certn, DocuSign, and backend APIs into production applications.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Improved application architecture, performance, and developer experience.</li>

              <li class="flex gap-2 print:hidden"><span class="text-accent font-bold">›</span> Configured Webpack, CI/CD pipelines, SonarQube, and engineering workflows.</li>
            </ul>
          </div>
        </div>

        <div class="relative flex gap-5">
          <div class="relative w-3 shrink-0">
            <span class="absolute left-1.5 top-3 -bottom-10 w-px bg-border"></span>
            <span class="absolute left-0 top-1 w-3 h-3 rounded-full bg-bg border-2 border-accent"></span>
          </div>
          <div class="pb-2">
            <p class="font-bold">Independent Full Stack Software Engineer</p>
            <p class="text-sm font-semibold text-accent-2 mt-0.5 mb-2.5">March 2023 — March 2025</p>
            <p class="text-sm text-text-secondary mb-2.5">
            Built production-ready full-stack applications for international clients across e-commerce, logistics, and SaaS platforms.
            </p>           
            <ul class="flex flex-col gap-2 text-sm text-text-secondary">
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Developed scalable backend services, microservices, scheduled jobs, and WebSocket features.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Integrated Shopify, Amazon, Walmart, Wix, Squarespace, and other marketplace APIs.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Built modular applications using micro-frontends and monorepo architectures.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Improved application quality through Playwright testing and automated development workflows.</li>

              <li class="flex gap-2 print:hidden"><span class="text-accent font-bold">›</span> Modernized legacy applications with contemporary frontend technologies.</li>
            </ul>
          </div>
        </div>

        <div class="relative flex gap-5">
          <div class="relative w-3 shrink-0">
            <span class="absolute left-1.5 top-3 -bottom-10 w-px bg-border"></span>
            <span class="absolute left-0 top-1 w-3 h-3 rounded-full bg-bg border-2 border-accent"></span>
          </div>
          <div class="pb-2">
            <p class="font-bold">Mid Full Stack Developer (MERN) · Penbrothers</p>
            <p class="text-sm font-semibold text-accent-2 mt-0.5 mb-2.5">June 2022 — March 2023</p>
            <p class="text-sm text-text-secondary mb-2.5">
            Built and maintained an Employee Management System (EMS) used by HR teams to manage employee records and workflows.
            </p>           
            <ul class="flex flex-col gap-2 text-sm text-text-secondary">
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Developed dynamic forms, dashboards, and data tables using the MERN stack.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Built reusable React components with Redux and Context API.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Resolved frontend and backend issues to improve application stability.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Collaborated on sprint planning, feature implementation, and technical design.</li>

              <li class="flex gap-2 print:hidden"><span class="text-accent font-bold">›</span> Worked within Agile workflows using Git and Jira.</li>
            </ul>
          </div>
        </div>

        <div class="relative flex gap-5">
          <div class="relative w-3 shrink-0">
            <span class="absolute left-1.5 top-3 -bottom-10 w-px bg-border"></span>
            <span class="absolute left-0 top-1 w-3 h-3 rounded-full bg-bg border-2 border-accent"></span>
          </div>
          <div class="pb-2">
            <p class="font-bold">Application Development Senior Analyst · Accenture</p>
            <p class="text-sm font-semibold text-accent-2 mt-0.5 mb-2.5">August 2021 — June 2022</p>
            <p class="text-sm text-text-secondary mb-2.5">
            Delivered enterprise web applications for telecommunications and insurance clients within Agile delivery teams.
            </p>            
            <ul class="flex flex-col gap-2 text-sm text-text-secondary">
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Built reusable frontend features for enterprise marketplace applications.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Delivered production-ready implementations aligned with client acceptance criteria.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Participated in sprint planning, estimation, and technical discussions.</li>

              <li class="flex gap-2 print:hidden"><span class="text-accent font-bold">›</span> Collaborated through Git workflows, Jira, pull requests, and code reviews.</li>
            </ul>
          </div>
        </div>

        <div class="relative flex gap-5">
          <div class="relative w-3 shrink-0">
            <span class="absolute left-1.5 top-3 -bottom-10 w-px bg-border"></span>
            <span class="absolute left-0 top-1 w-3 h-3 rounded-full bg-bg border-2 border-accent"></span>
          </div>
          <div class="pb-2">
            <p class="font-bold">Web Developer (part time) · NESTEACHERS.COM</p>
            <p class="text-sm font-semibold text-accent-2 mt-0.5 mb-2.5">December 2020 — March 2022</p>
            <p class="text-sm text-text-secondary mb-2.5">Developed recruitment and onboarding features for an online ESL hiring platform.</p>
            <ul class="flex flex-col gap-2 text-sm text-text-secondary">
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Built onboarding workflows, resume generation, and video interview features.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Developed REST and GraphQL APIs using Node.js and Express.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Built responsive React interfaces and full-stack application features.</li>

              <li class="flex gap-2 print:hidden"><span class="text-accent font-bold">›</span> Collaborated using Git and Agile development practices.</li>
            </ul>
          </div>
        </div>

        <div class="relative flex gap-5">
          <div class="relative w-3 shrink-0">
            <span class="absolute left-0 top-1 w-3 h-3 rounded-full bg-bg border-2 border-accent"></span>
          </div>
          <div>
            <p class="font-bold">Full Stack Software Engineer · Nueva Vizcaya State University</p>
            <p class="text-sm font-semibold text-accent-2 mt-0.5 mb-2.5">January 2018 — December 2021</p>
            <p class="text-sm text-text-secondary mb-2.5">Designed and built a university-wide document tracking system that replaced paper-based workflows.</p>
            <ul class="flex flex-col gap-2 text-sm text-text-secondary">
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Digitized document management with a centralized web application.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Implemented searchable PDF indexing and document retrieval.</li>
              <li class="flex gap-2"><span class="text-accent font-bold">›</span> Streamlined document routing and inter-office approvals.</li>
            </ul>
          </div>
        </div>

      </div>
    </section>

    <!-- ===== PROJECTS =====
         Rewritten as short engineering case studies (Problem → Approach →
         Tradeoffs → Outcome) instead of feature/README lists. Layout moved
         from a 3-up grid to full-width cards with a two-column split so
         there's room for the narrative without shrinking the type. -->
    <section id="projects" class="py-14 border-b border-border scroll-mt-16 print:hidden" aria-labelledby="projects-heading">
      <h2 id="projects-heading" class="flex items-center gap-2 text-xl sm:text-2xl font-bold mb-2">
        <span class="w-2 h-2 rounded-full bg-accent shrink-0"></span> Featured Projects
      </h2>
      <p class="max-w-2xl text-text-secondary mb-7 print:hidden">Personal projects that showcase my approach to building reliable, maintainable software systems.</p>

      <div class="flex flex-col gap-5">

        <article class="flex flex-col md:flex-row gap-6 bg-bg-elevated border border-border rounded-xl p-5 hover:border-accent transition-all">
          <img
            src="/public/images/cca/banner.png"
            alt="Placeholder preview of the NUVELCO CCA call center agent portal"
            class="w-full md:w-64 lg:w-72 h-52 md:h-auto object-cover rounded-lg border border-border shrink-0 print:hidden"
          >
          <div class="flex flex-col flex-1 min-w-0">
            <h3 class="font-bold text-lg mb-1">NUVELCO CCA Portal</h3>
            <p class="text-sm text-text-secondary mb-3">Reliability and offline continuity &bull; Personal Project &bull; Live in Production.</p>

            <p class="text-sm text-text-secondary mb-4">Keeps call center agents productive even when connectivity is unreliable.</p>

            <div class="mb-3">
              <p class="text-[11px] font-bold uppercase tracking-wide text-accent-2 mb-1.5">Key Decisions</p>
              <div class="flex flex-wrap gap-1.5">
                <span class="text-[11px] font-semibold text-text-secondary bg-bg-base border border-border px-2.5 py-1 rounded-full">Local-first</span>
                <span class="text-[11px] font-semibold text-text-secondary bg-bg-base border border-border px-2.5 py-1 rounded-full">OPFS</span>
                <span class="text-[11px] font-semibold text-text-secondary bg-bg-base border border-border px-2.5 py-1 rounded-full">Better Auth</span>
                <span class="text-[11px] font-semibold text-text-secondary bg-bg-base border border-border px-2.5 py-1 rounded-full">Docker</span>
              </div>
            </div>

            <p class="text-xs text-text-secondary mb-4">Built with TanStack Start &bull; TanStack DB &bull; React 19 &bull; Prisma 7</p>

            <a href="/nuvelco-cca.html" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent hover:text-accent-2 transition-colors print:hidden">
              Explore Architecture
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M7 7h10v10"/></svg>
            </a>
          </div>
        </article>

        <article class="flex flex-col md:flex-row gap-6 bg-bg-elevated border border-border rounded-xl p-5 hover:border-accent transition-all">
          <img
            src="/public/images/start-pos/banner.png"
            alt="Placeholder preview of the START POS multi-tenant offline-first POS platform"
            class="w-full md:w-64 lg:w-72 h-52 md:h-auto object-cover rounded-lg border border-border shrink-0 print:hidden"
          >
          <div class="flex flex-col flex-1 min-w-0">
            <h3 class="font-bold text-lg mb-1">START POS</h3>
            <p class="text-sm text-text-secondary mb-3">Multi-tenant business platform and operational resilience &bull; Personal Project &bull; Prototype</p>

            <p class="text-sm text-text-secondary mb-4">Offline-first POS platform that keeps checkout running during network interruptions.</p>

            <div class="mb-3">
              <p class="text-[11px] font-bold uppercase tracking-wide text-accent-2 mb-1.5">Key Decisions</p>
              <div class="flex flex-wrap gap-1.5">
                <span class="text-[11px] font-semibold text-text-secondary bg-bg-base border border-border px-2.5 py-1 rounded-full">Local-first sync</span>
                <span class="text-[11px] font-semibold text-text-secondary bg-bg-base border border-border px-2.5 py-1 rounded-full">Multi-tenant</span>
                <span class="text-[11px] font-semibold text-text-secondary bg-bg-base border border-border px-2.5 py-1 rounded-full">BIR reporting</span>
                <span class="text-[11px] font-semibold text-text-secondary bg-bg-base border border-border px-2.5 py-1 rounded-full">Quality tooling</span>
              </div>
            </div>

            <p class="text-xs text-text-secondary mb-4">Built with TanStack Start &bull; React 19 &bull; TanStack DB &bull; Prisma 7 &bull; Biome</p>

            <a href="/start-pos.html" target="_blank" rel="noopener noreferrer"
              class="inline-flex items-center gap-1.5 text-sm font-semibold text-accent hover:text-accent-2 transition-colors print:hidden">
              Explore Architecture
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M7 7h10v10"/></svg>
            </a>
          </div>
        </article>

        <article class="flex flex-col md:flex-row gap-6 bg-bg-elevated border border-border rounded-xl p-5 hover:border-accent transition-all">
          <img
            src="https://placehold.co/600x320/0f172a/10b981?text=overlay-manager"
