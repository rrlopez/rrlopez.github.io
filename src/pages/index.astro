---
import { personal } from '../data/personal';
import HomeLayout from '../layouts/HomeLayout.astro';
---

<HomeLayout title={"RJ Lopez — Senior Full Stack Engineer"} description={"Ricardo Rey Crisanto V. Lopez II (RJ) — Senior Full Stack Engineer, 7+ years building scalable SaaS platforms with the JavaScript/TypeScript ecosystem."}>
  <!-- ===== NAV ===== -->
  <nav class="sticky top-0 z-10 bg-bg/90 backdrop-blur border-b border-border print:hidden" aria-label="Section navigation">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-3 flex items-center justify-between relative">
      <a href="#top" class="font-bold text-text tracking-tight shrink-0">RJ<span class="text-accent">.</span>dev</a>

      <!-- Desktop links -->
      <div class="hidden md:flex items-center gap-5 text-sm font-medium text-text-secondary">
        <a href="#experience" class="hover:text-accent transition-colors">Experience</a>
        <a href="#projects" class="hover:text-accent transition-colors">Projects</a>
        <a href="#skills" class="hover:text-accent transition-colors">Skills</a>
        <a href="#blog" class="hover:text-accent transition-colors">Blog</a>
        <a href="#contact" class="hover:text-accent transition-colors">Contact</a>
        <button
          type="button"
          onclick="window.print()"
          aria-label="Download resume as PDF"
          class="inline-flex items-center gap-1.5 px-3.5 py-1.5 rounded-lg bg-accent text-bg text-xs font-semibold hover:bg-accent-2 hover:-translate-y-0.5 transition-all"
        >
          <svg class="w-3.5 h-3.5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14"/></svg>
          Download Resume
        </button>
      </div>

      <!-- Mobile controls -->
      <div class="flex md:hidden items-center gap-2">
        <button
          type="button"
          onclick="window.print()"
          aria-label="Download resume as PDF"
          class="inline-flex items-center justify-center w-9 h-9 rounded-lg bg-accent text-bg hover:bg-accent-2 transition-all"
        >
          <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v12m0 0 4-4m-4 4-4-4M5 21h14"/></svg>
        </button>
        <button
          type="button"
          id="nav-toggle"
          aria-label="Toggle navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-border text-text-secondary hover:text-accent hover:border-accent transition-colors"
        >
          <svg id="nav-icon-open" class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="nav-icon-close" class="w-5 h-5 hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>

      <!-- Mobile floating dropdown -->
      <div
        id="mobile-menu"
        class="md:hidden absolute top-full right-4 mt-2 w-56 rounded-xl border border-border bg-bg shadow-lg origin-top-right transform transition-all duration-200 ease-out opacity-0 scale-95 -translate-y-1 invisible pointer-events-none"
      >
        <div class="p-2 flex flex-col gap-1 text-sm font-medium text-text-secondary">
          <a href="#experience" class="py-2 px-3 rounded-lg hover:text-accent hover:bg-border/30 transition-colors">Experience</a>
          <a href="#projects" class="py-2 px-3 rounded-lg hover:text-accent hover:bg-border/30 transition-colors">Projects</a>
          <a href="#skills" class="py-2 px-3 rounded-lg hover:text-accent hover:bg-border/30 transition-colors">Skills</a>
          <a href="#blog" class="py-2 px-3 rounded-lg hover:text-accent hover:bg-border/30 transition-colors">Blog</a>
          <a href="#contact" class="py-2 px-3 rounded-lg hover:text-accent hover:bg-border/30 transition-colors">Contact</a>
        </div>
      </div>
    </div>
  </nav>

  <script>
    const toggle = document.getElementById('nav-toggle');
    const menu = document.getElementById('mobile-menu');
    const iconOpen = document.getElementById('nav-icon-open');
    const iconClose = document.getElementById('nav-icon-close');

    const OPEN_CLASSES = ['opacity-100', 'scale-100', 'translate-y-0'];
    const CLOSED_CLASSES = ['opacity-0', 'scale-95', '-translate-y-1'];

    function openMenu() {
      menu?.classList.remove('invisible', 'pointer-events-none', ...CLOSED_CLASSES);
      menu?.classList.add(...OPEN_CLASSES);
      iconOpen?.classList.add('hidden');
      iconClose?.classList.remove('hidden');
      toggle?.setAttribute('aria-expanded', 'true');
    }

    function closeMenu() {
      menu?.classList.remove(...OPEN_CLASSES);
      menu?.classList.add(...CLOSED_CLASSES, 'pointer-events-none');
      iconOpen?.classList.remove('hidden');
      iconClose?.classList.add('hidden');
      toggle?.setAttribute('aria-expanded', 'false');
      // wait for transition before hiding from a11y tree
      setTimeout(() => menu?.classList.add('invisible'), 200);
    }

    toggle?.addEventListener('click', () => {
      const isOpen = toggle.getAttribute('aria-expanded') === 'true';
      isOpen ? closeMenu() : openMenu();
    });

    menu?.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', closeMenu);
    });

    // Close when clicking outside
    document.addEventListener('click', (e) => {
      if (!menu?.contains(e.target as Node) && !toggle?.contains(e.target as Node)) {
        closeMenu();
      }
    });
  </script>

  <!-- ===== HEADER / HERO ===== -->
  <header id="top" class="border-b border-border">
    <div class="max-w-6xl mx-auto px-6 py-16 sm:py-20 print:py-4 flex flex-col sm:flex-row items-center sm:items-start gap-8 print:gap-0">

      <img
        src={personal.avatarUrl}
        alt={`Placeholder avatar for ${personal.fullName}`}
        width="160" height="160"
        class="w-32 h-32 sm:w-40 sm:h-40 rounded-full border-2 border-accent/40 shrink-0 object-cover print:hidden reveal reveal-fade"
      >

      <div class="text-center sm:text-left">
        <div class="inline-flex items-center gap-2 mb-3 px-3 py-1 rounded-full bg-bg-elevated border border-border print:hidden reveal reveal-fade">
          <span class="relative flex w-2 h-2">
            <span class="absolute inline-flex w-2 h-2 rounded-full bg-accent pulse-dot"></span>
            <span class="relative inline-flex w-2 h-2 rounded-full bg-accent"></span>
          </span>
          <span class="text-xs font-medium text-text-secondary">{personal.availability}</span>
        </div>

        <h1 class="text-3xl sm:text-4xl font-bold tracking-tight reveal">
          {personal.fullName} <span class="text-accent">({personal.nickname})</span>
        </h1>
        <p class="mt-2 text-base sm:text-lg text-text-secondary font-medium reveal">
          {personal.title} <span class="text-accent-2">·</span> {personal.yearsExperience}+ Years Experience
        </p>
        <p class="mt-1 text-sm text-text-secondary flex items-center justify-center sm:justify-start gap-1.5 reveal">
          <svg class="w-4 h-4 shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21c-4.5-4.5-7-8.06-7-11a7 7 0 1 1 14 0c0 2.94-2.5 6.5-7 11Z"/><circle cx="12" cy="10" r="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          {personal.location.display}
        </p>

        <p class="mt-4 max-w-xl text-text-secondary reveal">
          {personal.bio}
        </p>
        <p class="mt-3 max-w-xl text-text-secondary italic print:hidden reveal">
          {personal.tagline}
        </p>

        <!-- quick stats -->
        <div class="mt-6 flex justify-center sm:justify-start gap-6 sm:gap-8 print:hidden reveal-stagger">
          {personal.stats.map((stat)=>(<div class="text-center sm:text-left">
            <p class="text-2xl font-bold text-accent">{stat.value}</p>
            <p class="text-xs text-text-secondary">{stat.label}</p>
          </div>))}
        </div>

        <div class="mt-6 flex flex-wrap justify-center sm:justify-start gap-3 print:hidden reveal">
          <a href={`mailto:${personal.contact.email}`}
            class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-bg-elevated border border-border text-sm font-medium hover:border-accent hover:text-accent hover:-translate-y-0.5 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 0 0 2.22 0L21 8M5 19h14a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2Z"/></svg>
            {personal.contact.email}
          </a>
          <a href={`tel:+${personal.contact.phone.href}`}
            class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-bg-elevated border border-border text-sm font-medium hover:border-accent hover:text-accent hover:-translate-y-0.5 transition-all">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 5a2 2 0 0 1 2-2h2.28a1 1 0 0 1 .98.78l.74 3.34a1 1 0 0 1-.27.96l-1.5 1.5a11 11 0 0 0 5.18 5.18l1.5-1.5a1 1 0 0 1 .96-.27l3.34.74a1 1 0 0 1 .78.98V19a2 2 0 0 1-2 2h-1C8.16 21 3 15.84 3 9V8Z"/></svg>
            {personal.contact.phone.display}
          </a>
          <a href={personal.social.github.url} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-bg-elevated border border-border text-sm font-medium hover:border-accent hover:text-accent hover:-translate-y-0.5 transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12c0 5.08 3.29 9.39 7.86 10.91.57.1.78-.25.78-.55v-1.94c-3.2.7-3.87-1.36-3.87-1.36-.53-1.34-1.29-1.7-1.29-1.7-1.05-.72.08-.7.08-.7 1.17.08 1.78 1.2 1.78 1.2 1.03 1.77 2.7 1.26 3.36.96.1-.74.4-1.26.72-1.55-2.55-.29-5.23-1.28-5.23-5.7 0-1.26.45-2.29 1.2-3.1-.12-.29-.52-1.46.11-3.04 0 0 .98-.31 3.2 1.18a11.1 11.1 0 0 1 5.83 0c2.22-1.49 3.2-1.18 3.2-1.18.63 1.58.23 2.75.11 3.04.75.81 1.2 1.84 1.2 3.1 0 4.43-2.69 5.41-5.25 5.69.41.36.77 1.07.77 2.15v3.19c0 .3.21.66.79.55A11.51 11.51 0 0 0 23.5 12C23.5 5.65 18.35.5 12 .5Z"/></svg>
            GitHub
          </a>
          <!-- <a href={personal.social.linkedin.url} target="_blank" rel="noopener noreferrer"
            class="inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-bg-elevated border border-border text-sm font-medium hover:border-accent hover:text-accent hover:-translate-y-0.5 transition-all">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true"><path d="M20.45 20.45h-3.55v-5.57c0-1.33-.02-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.94v5.67H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.38-1.85 3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.22 0H1.77C.8 0 0 .78 0 1.75v20.5C0 23.22.8 24 1.77 24h20.45c.98 0 1.78-.78 1.78-1.75V1.75C24 .78 23.2 0 22.22 0Z"/></svg>
            LinkedIn
          </a> -->
        </div>

        <!-- print-only plain-text contact line: traditional resume header, no icons/buttons &nbsp;|&nbsp; {personal.social.linkedin.url} -->
        <p class="hidden print:block print:mt-2 print:text-sm">
          {personal.contact.email} &nbsp;|&nbsp; {personal.contact.phone.display} &nbsp;|&nbsp; {personal.social.portfolio.url} 
        </p>
      </div>
    </div>
  </header>

   <!-- ===== ENGINEERING FOCUS (new) =====
         Short "what I build" line so a recruiter or EM gets the mindset in
         the first few seconds — before the project details. Kept short on
         purpose per the brief; renders as a comma list in print, like the
         Skills tags, so it doubles as a "core focus" line on the resume. -->
    <section class="border-b border-border bg-bg-elevated/40 reveal" aria-label="Core technologies print:hidden">
      <div class="max-w-6xl mx-auto px-6 py-6 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm font-semibold text-text-secondary print:hidden">
        <span class="inline-flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h11M9 21V3m11 10-4-4m0 0-4 4m4-4v11"/></svg>
          Offline-First Applications
        </span><span class="text-border">/</span>
        <span class="inline-flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M12 21a9 9 0 1 0 0-18 9 9 0 0 0 0 18Zm0 0a9 9 0 0 0 9-9H3a9 9 0 0 0 9 9Z"/></svg>
          SaaS &amp; Multi-Tenant Platforms
        </span><span class="text-border">/</span>
        <span class="inline-flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M3 7h18M5 21h14a2 2 0 0 0 2-2V5a2 2 0 0 0-2-2H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2Zm4-10h6"/></svg>
          Clean, Maintainable Architecture
        </span><span class="text-border">/</span>
        <span class="inline-flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M9 3v2m6-2v2M9 19v2m6-2v2M5 9H3m2 6H3m18-6h-2m2 6h-2M7 19h10a2 2 0 0 0 2-2V7a2 2 0 0 0-2-2H7a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2Z"/></svg>
          Engineering Systems
        </span><span class="text-border">/</span>
        <span class="inline-flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="m7 21-4.3-4.3c-1-1-1-2.5 0-3.4l9.6-9.6c1-1 2.5-1 3.4 0L21 9M7 21l4-4m-4 4 6-14m8-4 4 4-10 10"/></svg>
          Modern TypeScript Ecosystem
        </span><span class="text-border">/</span>
        <span class="inline-flex items-center gap-2">
          <svg class="w-4 h-4 text-accent" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M14.25 9.75 16.5 12l-2.25 2.25m-4.5 0L7.5 12l2.25-2.25M6 20.25h12A2.25 2.25 0 0 0 20.25 18V6A2.25 2.25 0 0 0 18 3.75H6A2.25 2.25 0 0 0 3.75 6v12A2.25 2.25 0 0 0 6 20.25Z"/></svg>
          Developer Experience Mindset
        </span><span class="text-border">/</span>
      </div>
    </section>

  <main class="max-w-6xl mx-auto px-6">
    
    <!-- ===== WORK HISTORY (TIMELINE) =====
         Each entry now opens with what the product/team was, before the
         impact bullets, so the reader gets context before detail. -->
    <section id="experience" class="py-14 border-b border-border scroll-mt-16" aria-labelledby="experience-heading">
      <h2 id="experience-heading" class="flex items-center gap-2 text-xl sm:text-2xl font-bold mb-7 reveal">
        <!-- briefcase icon -->
        <svg class="w-5 h-5 text-accent shrink-0" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M20 7H4a2 2 0 0 0-2 2v10a2 2 0 0 0 2 2h16a2 2 0 0 0 2-2V9a2 2 0 0 0-2-2Zm0 0V6a2 2 0 0 0-2-2H6a2 2 0 0 0-2 2v1"/></svg>
        Work History
      </h2>

      <div class="flex flex-col gap-10 print:gap-1">

        <div class="relative flex gap-5 reveal-left">
          <div class="relative w-3 shrink-0">
            <span class="absolute left-1.5 top-3 -bottom-10 w-px bg-border"></span>
            <span class="absolute left-0 top-1 w-3 h-3 rounded-full bg-bg border-2 border-accent"></span>
          </div>
          <div class="pb-2">
            <p class="font-bold">Senior Full Stack Developer · iScale</p>
            <p class="text-sm font-semibold text-accent-2 mt-0.5 mb-2.5">March 2025 — July 2026</p>
            <ul class="flex flex-col gap-2 text-sm text-text-secondary">
              <li><span class="text-accent font-bold">›</span> Refactored legacy applications into reusable, maintainable React components.</li>
              <li><span class="text-accent font-bold">›</span> Modernized UI using Material UI, React Hook Form, and shared component libraries.</li>
              <li><span class="text-accent font-bold">›</span> Built responsive interfaces from Figma designs and maintained an internal design system.</li>
              <li><span class="text-accent font-bold">›</span> Integrated Stripe, Certn, DocuSign, and backend APIs into production applications.</li>
              <li><span class="text-accent font-bold">›</span> Improved application architecture, performance, and developer experience.</li>

              <li class="flex gap-2 print:hidden"><span class="text-accent font-bold">›</span> Configured Webpack, CI/CD pipelines, SonarQube, and engineering workflows.</li>
            </ul>
          </div>
        </div>

        <div class="relative flex gap-5 reveal-left">
          <div class="relative w-3 shrink-0">
            <span class="absolute left-1.5 top-3 -bottom-10 w-px bg-border"></span>
            <span class="absolute left-0 top-1 w-3 h-3 rounded-full bg-bg border-2 border-accent"></span>
          </div>
          <div class="pb-2">
            <!-- <a href="/experience/independent" class="group inline-flex items-center gap-2 font-bold hover:text-accent transition-colors print:pointer-events-none"> -->
              Independent Full Stack Software Engineer
              <!-- <svg class="w-3.5 h-3.5 opacity-0 group-hover:opacity-100 transition-opacity print:hidden" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M7 7h10v10"/></svg>
            </a> -->
            <p class="text-sm font-semibold text-accent-2 mt-0.5 mb-2.5">March 2023 — March 2025</p>
            <p class="text-sm text-text-secondary mb-2.5">
            Built production-ready full-stack applications for international clients across e-commerce, logistics, and SaaS platforms.
            </p>           
            <ul class="flex flex-col gap-2 text-sm text-text-secondary">
              <li><span class="text-accent font-bold">›</span> Developed scalable backend services, microservices, scheduled jobs, and WebSocket features.</li>
              <li><span class="text-accent font-bold">›</span> Integrated Shopify, Amazon, Walmart, Wix, Squarespace, and other marketplace APIs.</li>
              <li><span class="text-accent font-bold">›</span> Built modular applications using micro-frontends and monorepo architectures.</li>
              <li><span class="text-accent font-bold">›</span> Improved application quality through Playwright testing and automated development workflows.</li>

              <li class="flex gap-2 print:hidden"><span class="text-accent font-bold">›</span> Modernized legacy applications with contemporary frontend technologies.</li>
            </ul>
            <!-- <a href="/experience/independent" class="inline-flex items-center gap-1.5 mt-4 text-sm font-semibold text-accent hover:text-accent-2 transition-colors print:hidden">
              View projects
              <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M7 17 17 7M7 7h10v10"/></svg>
            </a> -->
          </div>
        </div>

        <div class="relative flex gap-5 reveal-left">
          <div class="relative w-3 shrink-0">
            <span class="absolute left-1.5 top-3 -bottom-10 w-px bg-border"></span>
            <span class="absolute left-0 top-1 w-3 h-3 rounded-full bg-bg border-2 border-accent"></span>
          </div>
          <div class="pb-2">
            <p class="font-bold">Mid Full Stack Developer (MERN) · Penbrothers</p>
            <p class="text-sm font-semibold text-accent-2 mt-0.5 mb-2.5">June 2022 — March 2023</p>
            <p class="text-sm text-text-secondary mb-2.5">
            Built and maintained an Employee Management System (EMS) used by HR teams to manage employee records and workflows.
            </p>           
            <ul class="flex flex-col gap-2 text-sm text-text-secondary">
              <li><span class="text-accent font-bold">›</span> Developed dynamic forms, dashboards, and data tables using the MERN stack.</li>
              <li><span class="text-accent font-bold">›</span> Built reusable React components with Redux and Context API.</li>
              <li><span class="text-accent font-bold">›</span> Resolved frontend and backend issues to improve application stability.</li>
              <li><span class="text-accent font-bold">›</span> Collaborated on sprint planning, feature implementation, and technical design.</li>

              <li class="flex gap-2 print:hidden"><span class="text-accent font-bold">›</span> Worked within Agile workflows using Git and Jira.</li>
            </ul>
          </div>
        </div>

        <div class="relative flex gap-5 reveal-left">
          <div class="relative w-3 shrink-0">
            <span class="absolute left-1.5 top-3 -bottom-10 w-px bg-border"></span>
            <span class="absolute left-0 top-1 w-3 h-3 rounded-full bg-bg border-2 border-accent"></span>
          </div>
          <div class="pb-2">
            <p class="font-bold">Application Development Senior Analyst · Accenture</p>
            <p class="text-sm font-semibold text-accent-2 mt-0.5 mb-2.5">August 2021 — June 2022</p>
            <p class="text-sm text-text-secondary mb-2.5">
            Delivered enterprise web applications for telecommunications and insurance clients within Agile delivery teams.
            </p>            
            <ul class="flex flex-col gap-2 text-sm text-text-secondary">
              <li><span class="text-accent font-bold">›</span> Built reusable frontend features for enterprise marketplace applications.</li>
              <li><span class="text-accent font-bold">›</span> Delivered production-ready implementations aligned with client acceptance criteria.</li>
              <li><span class="text-accent font-bold">›</span> Participated in sprint planning, estimation, and technical discussions.</li>

              <li class="flex gap-2 print:hidden"><span class="text-accent font-bold">›</span> Collaborated through Git workflows, Jira, pull requests, and code reviews.</li>
            </ul>
