<button
  id="scroll-top-btn"
  aria-label="Scroll to top"
  onclick="window.scrollTo({top: 0, behavior: 'smooth'})"
  class="fixed bottom-6 right-6 z-20 w-11 h-11 flex items-center justify-center rounded-full bg-accent text-bg shadow-lg shadow-accent/30 opacity-0 translate-y-2 pointer-events-none transition-all duration-300 hover:bg-accent-2 hover:-translate-y-0.5 print:hidden"
>
  <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M5 15l7-7 7 7"/></svg>
</button>

<script is:inline>
  const scrollBtn = document.getElementById('scroll-top-btn');
  window.addEventListener('scroll', () => {
    const visible = window.scrollY > 400;
    scrollBtn.classList.toggle('opacity-0', !visible);
    scrollBtn.classList.toggle('translate-y-2', !visible);
    scrollBtn.classList.toggle('pointer-events-none', !visible);
    scrollBtn.classList.toggle('opacity-100', visible);
    scrollBtn.classList.toggle('translate-y-0', visible);
  }, { passive: true });
</script>
